rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function queryMatches(existing) { 
      return request.resource != null && 
             request.resource.data.username == existing.username && 
             request.resource.data.dob == existing.dob; 
    }

    match /users/{userId} {
      allow get, list: if true;
      allow create: if true;
      allow update: if isOwner(userId) || queryMatches(resource.data);
      allow delete: if isOwner(userId); // Minimal restriction for safety
    }
  }
}
